rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ---------- Helpers ----------

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(resource) {
      return request.auth.uid == resource.data.ownerId;
    }

    function isMember(resource) {
      return request.auth.uid in resource.data.memberIds;
    }

    function isValidListWrite() {
      return request.resource.data.keys().hasAll([
        'title',
        'ownerId',
        'memberIds',
        'isArchived',
        'createdAt',
        'updatedAt',
        'items'
      ]);
    }

    // Self-join: non-member adds ONLY themselves to memberIds
    function isSelfJoinOnly() {
      let after = request.resource.data;
      let before = resource.data;
      return after.memberIds.hasAll(before.memberIds)
        && after.memberIds.size() == before.memberIds.size() + 1
        && request.auth.uid in after.memberIds
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['memberIds', 'updatedAt']);
    }

    // ---------- Users ----------

    match /users/{userId} {

      allow read, write: if isAuthenticated()
        && request.auth.uid == userId;
    }

    // ---------- Shopping Lists ----------

    match /shoppingLists/{listId} {

      // Read: only members
      allow read: if isAuthenticated()
        && isMember(resource);

      // Create: authenticated user must be owner
      allow create: if isAuthenticated()
        && request.resource.data.ownerId == request.auth.uid
        && isValidListWrite();

      // Update: members only
      allow update: if isAuthenticated()
        && isMember(resource)
        && isValidListWrite();

      // Update: self-join via invite code
      allow update: if isAuthenticated()
        && !isMember(resource)
        && isSelfJoinOnly();

      // Delete: owner only
      allow delete: if isAuthenticated()
        && isOwner(resource);
    }

    // ---------- Invites ----------

    match /invites/{code} {

      // `get` (fetch by document ID) is allowed for any authenticated user — needed for the
      // join flow where the user enters a code. Using `get` instead of `read` disables
      // collection listing, preventing enumeration of all invite codes.
      allow get: if isAuthenticated();

      // Only the list owner can create an invite
      allow create: if isAuthenticated()
        && request.resource.data.keys().hasAll(['listId', 'listTitle', 'ownerName', 'ownerId', 'createdAt'])
        && request.resource.data.ownerId == request.auth.uid;

      // Only the invite creator can delete
      allow delete: if isAuthenticated()
        && resource.data.ownerId == request.auth.uid;

      // Invites are immutable
      allow update: if false;
    }
  }
}
